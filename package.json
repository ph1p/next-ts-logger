{
	"name": "next-ts-logger",
	"type": "module",
	"version": "0.0.1",
	"private": false,
	"description": "A structured logger for Next.js compatible with Pino and Winston",
	"exports": {
		".": "./dist/index.mjs",
		"./package.json": "./package.json"
	},
	"main": "./dist/index.mjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "pnpm test && tsdown",
		"dev": "tsdown --watch",
		"lint": "biome lint",
		"format": "biome format --write && biome check --write",
		"test": "vitest run",
		"test:watch": "vitest",
		"prepublishOnly": "pnpm build"
	},
	"peerDependencies": {
		"next": ">=14.0.0",
		"pino": ">=8.0.0",
		"winston": ">=3.0.0"
	},
	"peerDependenciesMeta": {
		"pino": {
			"optional": true
		},
		"winston": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/node": "^25.0.3",
		"next": "^16.0.10",
		"pino": "^10.1.0",
		"tsdown": "^0.18.0",
		"typescript": "^5.9.3",
		"vitest": "^2.1.0"
	}
}
